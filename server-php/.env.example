# AICOUNTLY Engage Portal API (CodeIgniter 4.6)
# Copy to .env locally; NEVER commit a real .env.
# On cPanel, this file lives at public_html/api/.env

CI_ENVIRONMENT=production
app.baseURL=https://engage.aicountly.org/api/
app.indexPage=

# ---------------------------------------------------------------------------
# PostgreSQL (Engage portal database — dedicated; do not point at other apps)
# DB name, DB user, and password come ONLY from this file. Never hardcoded.
# ---------------------------------------------------------------------------
ENGAGE_DB_HOST=127.0.0.1
ENGAGE_DB_PORT=5432
ENGAGE_DB_NAME=engage_aicountly
ENGAGE_DB_USER=
ENGAGE_DB_PASSWORD=

# ---------------------------------------------------------------------------
# Auth & encryption (generate strong random values; never commit real secrets)
# Generate: php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
# ---------------------------------------------------------------------------
ENGAGE_JWT_SECRET=
ENGAGE_JWT_TTL_MINUTES=720

# CORS — comma-separated origins allowed to call the API.
ENGAGE_ALLOWED_ORIGINS=https://engage.aicountly.org,http://localhost:5173

# ---------------------------------------------------------------------------
# Console orchestrator (outbound: Engage -> Console)
# ---------------------------------------------------------------------------
CONTROLLER_APP_CODE=engage
CONSOLE_API_URL=https://console.aicountly.org/api
CONSOLE_API_BASE_URL=https://console.aicountly.org/api
# Shared secret used both:
#   - as the value of the X-Console-Portal-Key header on outbound Engage -> Console calls
#   - as the Bearer token Console uses to call back into Engage (portal/bot/*)
# Must match Console's ENGAGE_BOT_SERVICE_KEY / bot_portals.service_key_hash.
CONSOLE_INBOUND_KEY=
ENGAGE_SERVICE_KEY=

# ---------------------------------------------------------------------------
# Playwright worker (worker.apis.aicountly.com — screenshots/reports only)
# ---------------------------------------------------------------------------
WORKER_BASE_URL=https://worker.apis.aicountly.com
WORKER_API_TOKEN=

# ---------------------------------------------------------------------------
# Reach ingest (Reach campaign leads -> POST /api/internal/reach/leads)
# Reach sends header  X-Portal-Token: <REACH_INBOUND_TOKEN>
# ---------------------------------------------------------------------------
REACH_INBOUND_TOKEN=

# ---------------------------------------------------------------------------
# Manage licensing (optional; service placeholder only, not wired)
# ---------------------------------------------------------------------------
MANAGE_API_BASE_URL=
MANAGE_API_TOKEN=

# ---------------------------------------------------------------------------
# LLM provider for the Sales Bot (optional; deterministic fallback if empty)
# ---------------------------------------------------------------------------
ENGAGE_LLM_PROVIDER=
ENGAGE_LLM_API_KEY=
ENGAGE_LLM_MODEL=

# ---------------------------------------------------------------------------
# Credit approval routing — amounts above this threshold require approval.
# ---------------------------------------------------------------------------
ENGAGE_CREDIT_LARGE_THRESHOLD=10000

# ---------------------------------------------------------------------------
# Initial Owner (OwnerSeeder — first deploy only)
# ---------------------------------------------------------------------------
# ENGAGE_OWNER_EMAIL=owner@aicountly.org
# ENGAGE_OWNER_NAME=Engage Owner
# ENGAGE_OWNER_PASSWORD=
