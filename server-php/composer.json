{
    "name": "aicountly/engage-api",
    "description": "AICOUNTLY Engage Portal API (CodeIgniter 4.6 + PostgreSQL). Internal sales/CRM portal with local Sales Bot and Console/Worker/Reach integrations.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.6",
        "firebase/php-jwt": "^6.10 || ^7.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@composer dump-autoload"
        ],
        "migrate": "php spark migrate",
        "seed:roles": "php spark db:seed RolesSeeder",
        "seed:products": "php spark db:seed ProductsSeeder",
        "seed:stages": "php spark db:seed PipelineStagesSeeder",
        "seed:actions": "php spark db:seed BotActionsSeeder",
        "seed:sources": "php spark db:seed LeadSourcesSeeder",
        "seed:settings": "php spark db:seed SettingsSeeder",
        "seed:owner": "php spark db:seed OwnerSeeder",
        "seed:all": [
            "@seed:roles",
            "@seed:products",
            "@seed:stages",
            "@seed:actions",
            "@seed:sources",
            "@seed:settings",
            "@seed:owner"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
